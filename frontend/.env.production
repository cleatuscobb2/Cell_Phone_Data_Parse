# Production build configuration — baked into the client bundle by Vite.
#
# Everything here is public-by-design client config: the Firebase *web*
# config is meant to ship in the browser bundle (access is controlled by
# Firebase Auth + authorized domains, not by secrecy of these values), and
# the API base is a public URL. Secrets (the Anthropic key) live only in
# Firebase Functions secrets — never here.

# Deployed backend — Firebase Cloud Functions entry point.
VITE_API_BASE=https://us-central1-family-legal-311e8.cloudfunctions.net/api

# Firebase web app config ("familylegal" app in the family-legal-311e8
# project) — enables the Google sign-in gate.
VITE_FIREBASE_API_KEY=AIzaSyBp58IF9NeAESOxeqbkQc5pjqrhBztMQEc
VITE_FIREBASE_AUTH_DOMAIN=family-legal-311e8.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=family-legal-311e8
VITE_FIREBASE_APP_ID=1:645448838066:web:58441771a074af905392ab
