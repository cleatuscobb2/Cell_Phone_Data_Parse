# Copy to .env.local for local dev, and set the same keys in the Vercel
# project's Environment Variables for production.

# Backend API base URL.
#   Local dev:  the FastAPI proxy
#   Production: the deployed Firebase "api" function URL
#               (e.g. https://api-xxxxxxxx-uc.a.run.app)
VITE_API_BASE=http://localhost:8000

# Firebase web config — Firebase Console > Project settings > Your apps > SDK.
# These are NOT secret; they ship in the client bundle.
# Leave them blank for local dev to run WITHOUT the sign-in gate.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
